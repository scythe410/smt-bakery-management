# Copy to `.env.local` and fill in. Never commit real values.
# .env* is gitignored (except this example file).

# --- Supabase (added in a later step; documented here up front) ---
# Public — safe to expose to the browser (NEXT_PUBLIC_*). URL + anon key only.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. NEVER expose to the client, never prefix with NEXT_PUBLIC_.
# Used only in server code (route handlers / server actions / RPC callers).
SUPABASE_SERVICE_ROLE_KEY=

# --- App ---
# Public base URL of the deployed app (used for auth redirects, absolute links).
NEXT_PUBLIC_SITE_URL=http://localhost:3000
